# ── 許可リスト方式 ──
# まずリポジトリ直下を全部無視する
/*

# 公開したいものだけ明示的に許可する
!/.claude/
!/.github/
!/.specdb/
!/examples/
!/README.md
!/.gitignore
!/.gitattributes
!/.vscode/
/.vscode/*
!/.vscode/settings.json

# 許可フォルダ内でも、これらは公開しない
__pycache__/
*.pyc
build/
*.egg-info/
# 生成ビュー (specdb generate/visualize で再生成できる) は追跡しない
/.specdb/out/
/examples/spec-pipeline-selfspec/.specdb/out/
